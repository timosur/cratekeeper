# Cratekeeper API — frontend env vars
# Copy this file to `.env.local` and adjust for your local backend.

# Base URL of the Cratekeeper FastAPI backend. No trailing slash.
VITE_API_BASE_URL=http://localhost:8765

# Bearer token sent in `Authorization: Bearer <token>` for every API call.
# Must match the backend's `CRATEKEEPER_API_TOKEN` environment variable.
VITE_API_TOKEN=
